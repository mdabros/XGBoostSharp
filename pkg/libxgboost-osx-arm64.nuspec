<?xml version="1.0"?>
<package>
  <metadata>
    <id>libxgboost-2.0.3-osx-arm64</id>
    <version>$version$</version>
    <authors>mdabros</authors>
    <description>XGBoost native library for macOS ARM64. This package contains the libxgboost.dylib native library built for macOS ARM64 (Apple Silicon) platforms.</description>
    <license type="expression">Apache-2.0</license>
    <projectUrl>https://github.com/mdabros/XGBoostSharp</projectUrl>
    <repository type="git" url="https://github.com/mdabros/XGBoostSharp" />
    <tags>xgboost native macos osx arm64 machine-learning</tags>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <readme>README.md</readme>
  </metadata>
  <files>
    <!-- Native libraries -->
    <file src="..\native\osx-arm64\libxgboost.dylib" target="runtimes\osx-arm64\native\libxgboost.dylib" />
    <file src="..\native\osx-arm64\libomp.dylib" target="runtimes\osx-arm64\native\libomp.dylib" />

    <!-- Build targets to copy libomp to .dylibs -->
    <file src="libxgboost-osx-arm64.targets" target="build\libxgboost-2.0.3-osx-arm64.targets" />
    <file src="libxgboost-osx-arm64.targets" target="buildTransitive\libxgboost-2.0.3-osx-arm64.targets" />

    <!-- README -->
    <file src="README-NATIVE.md" target="README.md" />
  </files>
</package>
