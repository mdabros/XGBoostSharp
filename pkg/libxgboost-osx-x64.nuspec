<?xml version="1.0"?>
<package>
  <metadata>
    <id>libxgboost-3.2.0-osx-x64</id>
    <version>$version$</version>
    <authors>mdabros</authors>
    <description>XGBoost native library for macOS x64. This package contains the libxgboost.dylib native library built for macOS x64 platforms.</description>
    <license type="expression">Apache-2.0</license>
    <projectUrl>https://github.com/mdabros/XGBoostSharp</projectUrl>
    <repository type="git" url="https://github.com/mdabros/XGBoostSharp" />
    <tags>xgboost native macos osx machine-learning</tags>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <readme>README.md</readme>
  </metadata>
  <files>
    <!-- Native libraries -->
    <file src="..\native\osx-x64\libxgboost.dylib" target="runtimes\osx-x64\native\libxgboost.dylib" />
    <file src="..\native\osx-x64\libomp.dylib" target="runtimes\osx-x64\native\libomp.dylib" />

    <!-- Build targets to patch libxgboost.dylib rpath for libomp -->
    <file src="libxgboost-osx-x64.targets" target="build\libxgboost-3.2.0-osx-x64.targets" />
    <file src="libxgboost-osx-x64.targets" target="buildTransitive\libxgboost-3.2.0-osx-x64.targets" />

    <!-- README -->
    <file src="README-NATIVE.md" target="README.md" />
  </files>
</package>
